{
  "name": "llm-proxy-gateway",
  "version": "1.0.0",
  "description": "Anthropic <-> OpenRouter API conversion gateway with dynamic multi-port proxies, TypeScript and React",
  "type": "module",
  "main": "src/gateway.ts",
  "bin": {
    "llm-proxy": "./bin/cli.mjs"
  },
  "scripts": {
    "start": "tsx src/gateway.ts",
